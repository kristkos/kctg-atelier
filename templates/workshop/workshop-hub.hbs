<div class="kctg-app kctg-workshop-inner">

  <div class="kctg-tab-bar">
    <button class="kctg-tab-btn {{#if isOverview}}kctg-tab-active{{/if}}"    data-tab="overview"     type="button"><i class="fas fa-tachometer-alt"></i> Overview</button>
    <button class="kctg-tab-btn {{#if isWorkers}}kctg-tab-active{{/if}}"     data-tab="workers"      type="button"><i class="fas fa-users"></i> Workers{{#if totalWorkers}}<span class="kctg-tab-badge">{{totalWorkers}}</span>{{/if}}</button>
    <button class="kctg-tab-btn {{#if isTasks}}kctg-tab-active{{/if}}"       data-tab="tasks"        type="button"><i class="fas fa-tasks"></i> Tasks{{#if activeCount}}<span class="kctg-tab-badge kctg-badge-active">{{activeCount}}</span>{{/if}}</button>
    <button class="kctg-tab-btn {{#if isMap}}kctg-tab-active{{/if}}"         data-tab="map"          type="button"><i class="fas fa-map"></i> Map</button>
    <button class="kctg-tab-btn {{#if isTradeOrders}}kctg-tab-active{{/if}}" data-tab="tradeOrders"  type="button"><i class="fas fa-scroll"></i> Trade Orders{{#if totalTradeOrders}}<span class="kctg-tab-badge">{{totalTradeOrders}}</span>{{/if}}</button>
    <button class="kctg-tab-btn {{#if isInventory}}kctg-tab-active{{/if}}"   data-tab="inventory"    type="button"><i class="fas fa-box-open"></i> Inventory{{#if totalInventory}}<span class="kctg-tab-badge">{{totalInventory}}</span>{{/if}}</button>
    <button class="kctg-tab-btn {{#if isTracker}}kctg-tab-active{{/if}}"     data-tab="tracker"      type="button"><i class="fas fa-chart-line"></i> Tracker{{#if trackerEntries.length}}<span class="kctg-tab-badge">{{trackerEntries.length}}</span>{{/if}}</button>
  </div>

  <div class="kctg-tab-content">

    {{!-- ═══ OVERVIEW ═══ --}}
    {{#if isOverview}}
    <div class="kctg-overview-tab">

      {{!-- Banner --}}
      <div class="kctg-banner-wrap">
        <div class="kctg-banner-area {{#unless workshopBanner}}kctg-banner-empty{{/unless}}"
             {{#if workshopBanner}}style="background-image:url('{{workshopBanner}}')"{{/if}}>
          {{#unless workshopBanner}}
            <span class="kctg-banner-hint">{{#if isGM}}Click to set banner image{{else}}Workshop{{/if}}</span>
          {{/unless}}
          {{#if isGM}}{{#if workshopBanner}}
            <button class="kctg-banner-clear kctg-btn kctg-btn-xs kctg-btn-danger" type="button">×</button>
          {{/if}}{{/if}}
        </div>
      </div>

      {{!-- Workshop name --}}
      <div class="kctg-ws-name-row">
        {{#if isGM}}
          <input class="kctg-ws-name-input kctg-input kctg-input-title" type="text"
                 value="{{workshopName}}" placeholder="Workshop name…" />
        {{else}}
          <span class="kctg-ws-title">{{workshopName}}</span>
        {{/if}}
        <p class="kctg-opened-tagline">
          <span>{{workshopName}} has been open for <strong>{{daysOpenStr}}</strong>.</span>
          {{#if worldDateStr}}<span class="kctg-overview-date">{{worldDateStr}}</span>{{/if}}
        </p>
        {{#if wsActorCoinage}}<p class="kctg-coinage-line">Treasury: <strong>{{wsActorCoinage}}</strong></p>{{/if}}
      </div>

      {{!-- Stats --}}
      <div class="kctg-stat-row">
        <div class="kctg-stat-card"><span class="kctg-stat-num">{{totalWorkers}}</span><span class="kctg-stat-lbl">Workers</span></div>
        <div class="kctg-stat-card"><span class="kctg-stat-num">{{idleCount}}</span><span class="kctg-stat-lbl">Idle</span></div>
        <div class="kctg-stat-card"><span class="kctg-stat-num">{{activeCount}}</span><span class="kctg-stat-lbl">Active</span></div>
        <div class="kctg-stat-card"><span class="kctg-stat-num">{{totalTasks}}</span><span class="kctg-stat-lbl">Tasks</span></div>
        <div class="kctg-stat-card"><span class="kctg-stat-num">{{totalTradeOrders}}</span><span class="kctg-stat-lbl">Trade Orders</span></div>
      </div>

      {{#if workers.length}}
        <div class="kctg-panel-header"><i class="fas fa-users"></i> Workers</div>
        <ul class="kctg-overview-worker-list">
          {{#each workers}}
          <li class="kctg-overview-worker-row">
            <img class="kctg-actor-img" src="{{img}}" alt="{{name}}" onerror="this.src='icons/svg/mystery-man.svg'" />
            <span class="kctg-ow-name">{{name}}</span>
            <span class="kctg-ow-status">{{#if isIdle}}<i class="fas fa-couch kctg-dim"></i> Idle{{else}}<i class="{{taskIcon}}" style="color:var(--kctg-gold)"></i> {{currentTask.name}}{{/if}}</span>
            <span class="kctg-morale-pip {{kctg_moraleClass morale}}" title="Morale">♥ {{morale}}</span>
            <span class="kctg-loyalty-pip" style="color:{{kctg_loyaltyColor loyalty}}" title="Loyalty">⚑ {{loyalty}}</span>
          </li>
          {{/each}}
        </ul>
      {{/if}}
      <div class="kctg-mode-badge"><i class="fas fa-cog"></i> Participation: <strong>{{modeLabel}}</strong></div>
    </div>
    {{/if}}

    {{!-- ═══ WORKERS ═══ --}}
    {{#if isWorkers}}
    {{#if wsActor}}
      <div class="kctg-ws-art-layer" style="background-image:url('{{wsActor.img}}');"></div>
    {{/if}}
    <div class="kctg-workers-tab">

      <div class="kctg-workers-toolbar">
        <div class="kctg-actor-drop-zone kctg-drop-zone kctg-drop-inline">
          <i class="fas fa-user-plus"></i> <span>Drop <strong>Actor</strong> to add worker</span>
        </div>
        <button class="kctg-add-worker        kctg-btn kctg-btn-outline kctg-btn-sm" type="button"><i class="fas fa-plus"></i> Add manually</button>
        <button class="kctg-add-group         kctg-btn kctg-btn-outline kctg-btn-sm" type="button"><i class="fas fa-layer-group"></i> Add Group</button>
        <button class="kctg-add-worker-folder kctg-btn kctg-btn-outline kctg-btn-sm" type="button"><i class="fas fa-folder-plus"></i> Add Folder</button>
        {{#if isGM}}<button class="kctg-worker-settings-toggle kctg-btn kctg-btn-outline kctg-btn-sm {{#if workerSettingsOpen}}kctg-btn-gold{{/if}}" type="button"><i class="fas fa-cog"></i> Settings</button>{{/if}}
      </div>

      {{#if workerSettingsOpen}}
      <div class="kctg-settings-panel">
        <div class="kctg-settings-inline-row">
          <span class="kctg-settings-lbl">Morale 10 - bonus roll %</span>
          <input class="kctg-setting-input kctg-input-qty" type="number" min="0" max="100" step="5" data-setting="moraleHighRerollChance" value="{{moraleHighChance}}" />
          <span class="kctg-settings-sep"></span>
          <span class="kctg-settings-lbl">Morale 0 - skip roll %</span>
          <input class="kctg-setting-input kctg-input-qty" type="number" min="0" max="100" step="5" data-setting="moraleLowSkipChance" value="{{moraleLowChance}}" />
          <span class="kctg-settings-sep"></span>
          <span class="kctg-settings-lbl">Loyalty 10 - speed bonus %</span>
          <input class="kctg-setting-input kctg-input-qty" type="number" min="0" max="100" step="5" data-setting="loyaltyHighSpeedChance" value="{{loyaltyHighChance}}" />
          <span class="kctg-settings-sep"></span>
          <span class="kctg-settings-lbl">Loyalty 0 - slowdown %</span>
          <input class="kctg-setting-input kctg-input-qty" type="number" min="0" max="100" step="5" data-setting="loyaltyLowSlowChance" value="{{loyaltyLowChance}}" />
        </div>
        {{!-- Morale automation: off = fully manual morale (the original behavior) --}}
        <div class="kctg-settings-inline-row">
          <span class="kctg-settings-lbl">Morale automation</span>
          <button class="kctg-morale-auto-toggle kctg-btn kctg-btn-xs {{#if moraleAuto}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}" type="button"
                  title="When on, morale drifts toward the baseline over time and completed tasks give +1 morale. When off, morale only changes when you edit it.">
            <i class="fas fa-wand-magic-sparkles"></i> {{#if moraleAuto}}On{{else}}Manual{{/if}}
          </button>
          {{#if moraleAuto}}
          <span class="kctg-settings-sep"></span>
          <span class="kctg-settings-lbl">Baseline</span>
          <input class="kctg-setting-input kctg-input-qty" type="number" min="0" max="10" step="1" data-setting="moraleBaseline" value="{{moraleBaseline}}" title="Morale drifts toward this value" />
          <span class="kctg-settings-sep"></span>
          <span class="kctg-settings-lbl">Drift every (days)</span>
          <input class="kctg-setting-input kctg-input-qty" type="number" min="0" max="99" step="1" data-setting="moraleDriftDays" value="{{moraleDriftDays}}" title="Days per 1-point drift toward the baseline (0 = no drift, task bonuses only)" />
          {{/if}}
        </div>
      </div>
      {{/if}}

      {{#if groups.length}}
      <ul class="kctg-group-list">
        {{#each groups}}
        <li class="kctg-group-card">
          <div class="kctg-group-header">
            <i class="fas fa-layer-group" style="color:var(--kctg-gold-dim)"></i>
            <input class="kctg-group-name kctg-input kctg-input-sub" type="text" value="{{name}}" data-id="{{id}}" placeholder="Group name" />
            <span class="kctg-hint" style="font-size:0.72rem;">{{members.length}} members · {{idleCount}} idle</span>
            <button class="kctg-delete-group kctg-btn kctg-btn-danger kctg-btn-xs" data-id="{{id}}" type="button"><i class="fas fa-times"></i></button>
          </div>
          <div class="kctg-group-members">
            {{#each members}}
              <span class="kctg-worker-tag">
                <img src="{{img}}" alt="{{name}}" onerror="this.src='icons/svg/mystery-man.svg'" />
                {{name}}
                <button class="kctg-group-remove-worker kctg-btn kctg-btn-xs" data-group-id="{{../id}}" data-worker-id="{{id}}" type="button" style="padding:0 3px;border:none;background:transparent;color:var(--kctg-danger);">×</button>
              </span>
            {{/each}}
            {{#if @root.workers.length}}
            <select class="kctg-group-add-worker kctg-select kctg-select-sm" data-id="{{id}}">
              <option value="">+ Add worker…</option>
              {{#each @root.workers}}<option value="{{id}}">{{name}}</option>{{/each}}
            </select>
            {{/if}}
          </div>
        </li>
        {{/each}}
      </ul>
      {{/if}}

      <div class="kctg-roster-grid kctg-ungrouped">

        <div class="kctg-retainer-card kctg-drop-zone {{#if hasWsActor}}kctg-slot-filled{{/if}} kctg-ws-actor-slot">
          {{#if hasWsActor}}
            <img class="kctg-retainer-art" src="{{wsActor.img}}" alt="{{wsActor.name}}"
                 onerror="this.src='icons/svg/mystery-man.svg'" />
            <div class="kctg-retainer-overlay">
              <span class="kctg-retainer-tag">Retainer</span>
              <span class="kctg-retainer-name">{{wsActor.name}}</span>
            </div>
            {{#if isGM}}<button class="kctg-ws-actor-clear kctg-btn kctg-btn-xs kctg-btn-danger kctg-retainer-clear" type="button" title="Remove">×</button>{{/if}}
          {{else}}
            <div class="kctg-retainer-empty">
              <span style="display:flex;align-items:center;justify-content:center;width:48px;height:48px;flex-shrink:0;margin-bottom:6px;opacity:0.40;" aria-hidden="true">
                <i class="fas fa-user" style="font-size:1.8rem;color:#f5b430;-webkit-text-fill-color:#f5b430;"></i>
              </span>
              <span class="kctg-retainer-tag">Retainer</span>
              <span class="kctg-retainer-hint">{{#if isGM}}Drop an actor{{else}}No retainer set{{/if}}</span>
            </div>
          {{/if}}
        </div>

        {{#each ungroupedWorkers}}
        <div class="kctg-worker-card kctg-grid-card" draggable="true" data-worker-id="{{id}}">
          {{#if artImg}}<img class="kctg-worker-art" src="{{artImg}}" alt="" onerror="this.remove()" />{{/if}}
          <div class="kctg-worker-actions">
            <button class="kctg-worker-edit" data-id="{{id}}" type="button" title="Rename worker"><i class="fas fa-pen"></i></button>
            <button class="kctg-delete-worker kctg-worker-clear" data-id="{{id}}" type="button" title="Delete worker"><i class="fas fa-times"></i></button>
          </div>
          <div class="kctg-worker-footer">
            <div class="kctg-worker-header">
              <span class="kctg-worker-tag-lbl">Worker</span>
              <span class="kctg-worker-name-text">{{name}}</span>
            </div>
            <div class="kctg-worker-sliders">
              <div class="kctg-slider-row"><span class="kctg-slider-lbl">Morale</span><input class="kctg-worker-morale kctg-stat-input {{kctg_moraleClass morale}}" type="number" min="0" max="10" step="1" value="{{morale}}" data-id="{{id}}" title="Morale (0-10)" /></div>
              <div class="kctg-slider-row"><span class="kctg-slider-lbl">Loyalty</span><input class="kctg-worker-loyalty kctg-stat-input" type="number" min="0" max="10" step="1" value="{{loyalty}}" data-id="{{id}}" style="color:{{kctg_loyaltyColor loyalty}}" title="Loyalty (0-10)" /></div>
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      {{#each workerFolderList}}
      <div class="kctg-folder-section">
        <div class="kctg-folder-header">
          <button class="kctg-folder-toggle kctg-btn-bare" data-id="{{id}}" data-kind="wf" type="button">
            <i class="fas fa-folder{{#unless collapsed}}-open{{/unless}}" style="color:var(--kctg-gold-dim)"></i>
          </button>
          <input class="kctg-wfolder-name kctg-input kctg-input-sub" type="text" value="{{name}}" data-id="{{id}}" placeholder="Folder name" />
          <span class="kctg-hint" style="font-size:0.72rem;">{{workers.length}} workers</span>
          <button class="kctg-delete-wfolder kctg-btn kctg-btn-danger kctg-btn-xs" data-id="{{id}}" type="button"><i class="fas fa-times"></i></button>
        </div>
        {{#unless collapsed}}
        <div class="kctg-folder-drop kctg-folder-grid-wrap" data-folder-id="{{id}}">
          {{#if workers.length}}
          <div class="kctg-roster-grid kctg-folder-grid">
            {{#each workers}}
            <div class="kctg-worker-card kctg-grid-card" draggable="true" data-worker-id="{{id}}">
              {{#if artImg}}<img class="kctg-worker-art" src="{{artImg}}" alt="" onerror="this.remove()" />{{/if}}
              <div class="kctg-worker-actions">
                <button class="kctg-worker-edit" data-id="{{id}}" type="button" title="Rename worker"><i class="fas fa-pen"></i></button>
                <button class="kctg-delete-worker kctg-worker-clear" data-id="{{id}}" type="button" title="Delete worker"><i class="fas fa-times"></i></button>
              </div>
              <div class="kctg-worker-footer">
                <div class="kctg-worker-header">
                  <span class="kctg-worker-tag-lbl">Worker</span>
                  <span class="kctg-worker-name-text">{{name}}</span>
                </div>
                <div class="kctg-worker-sliders">
                  <div class="kctg-slider-row"><span class="kctg-slider-lbl">Morale</span><input class="kctg-worker-morale kctg-stat-input {{kctg_moraleClass morale}}" type="number" min="0" max="10" step="1" value="{{morale}}" data-id="{{id}}" title="Morale (0-10)" /></div>
                  <div class="kctg-slider-row"><span class="kctg-slider-lbl">Loyalty</span><input class="kctg-worker-loyalty kctg-stat-input" type="number" min="0" max="10" step="1" value="{{loyalty}}" data-id="{{id}}" style="color:{{kctg_loyaltyColor loyalty}}" title="Loyalty (0-10)" /></div>
                </div>
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="kctg-folder-empty-drop"><i class="fas fa-arrows-alt"></i> Drag worker cards here</div>
          {{/if}}
        </div>
        {{/unless}}
      </div>
      {{/each}}

    </div>
    {{/if}}

    {{!-- ═══ TASKS ═══ --}}
    {{#if isTasks}}
    <div class="kctg-tasks-tab">

      {{#if isGM}}
      <div class="kctg-day-strip">
        <i class="fas fa-calendar-alt" style="color:var(--kctg-gold-dim);flex-shrink:0;"></i>
        <span class="kctg-day-strip-label" style="flex-shrink:0;">Day</span>
        {{#if worldBound}}
        <span class="kctg-day-num" style="flex-shrink:0;">{{curDay}}</span>
        <span class="kctg-world-date" style="flex-shrink:0;opacity:.8;font-style:italic;" title="Following Foundry's world clock"><i class="fas fa-link" style="font-size:.7em;margin-right:3px;"></i>{{worldDateStr}}</span>
        <button class="kctg-day-minus10 kctg-btn kctg-btn-outline kctg-btn-xs" type="button" style="flex-shrink:0;">−10</button>
        <button class="kctg-day-minus   kctg-btn kctg-btn-outline kctg-btn-xs" type="button" style="flex-shrink:0;">−1</button>
        <button class="kctg-day-plus    kctg-btn kctg-btn-gold    kctg-btn-xs" type="button" style="flex-shrink:0;">+1</button>
        <button class="kctg-day-plus10  kctg-btn kctg-btn-gold    kctg-btn-xs" type="button" style="flex-shrink:0;">+10</button>
        <button class="kctg-set-opened  kctg-btn kctg-btn-outline kctg-btn-xs" type="button" style="flex-shrink:0;" title="Mark today as workshop opening day">Mark opened today</button>
        {{else if fineCtl}}
        <div class="kctg-fine-row" style="margin:0;flex-shrink:0;">
          <div class="kctg-fine-field"><label>Year</label><input class="kctg-fine-year  kctg-input-qty" type="number" min="0" value="{{curYear}}" /></div>
          <div class="kctg-fine-field"><label>Month</label><input class="kctg-fine-month kctg-input-qty" type="number" min="0" max="11" value="{{curMonth}}" /></div>
          <div class="kctg-fine-field"><label>Day</label><input class="kctg-fine-day   kctg-input-qty" type="number" min="0" max="29" value="{{curDayRem}}" /></div>
        </div>
        {{else}}
        <input  class="kctg-day-direct  kctg-input-qty kctg-day-num" type="number" min="1" value="{{curDay}}" style="flex-shrink:0;" />
        <button class="kctg-day-minus10 kctg-btn kctg-btn-outline kctg-btn-xs" type="button" style="flex-shrink:0;">−10</button>
        <button class="kctg-day-minus   kctg-btn kctg-btn-outline kctg-btn-xs" type="button" style="flex-shrink:0;">−1</button>
        <button class="kctg-day-plus    kctg-btn kctg-btn-gold    kctg-btn-xs" type="button" style="flex-shrink:0;">+1</button>
        <button class="kctg-day-plus10  kctg-btn kctg-btn-gold    kctg-btn-xs" type="button" style="flex-shrink:0;">+10</button>
        <button class="kctg-set-opened  kctg-btn kctg-btn-outline kctg-btn-xs" type="button" style="flex-shrink:0;" title="Mark today as workshop opening day">Mark opened today</button>
        {{/if}}
        <span style="flex:1;min-width:0;"></span>
        <button class="kctg-open-event-tables kctg-btn kctg-btn-outline kctg-btn-xs" type="button" style="flex-shrink:0;"><i class="fas fa-dice-d20"></i> Event Tables</button>
        <button class="kctg-add-task          kctg-btn kctg-btn-gold    kctg-btn-xs" type="button" style="flex-shrink:0;"><i class="fas fa-plus"></i> Add Task</button>
      </div>
      {{else}}
      {{!-- Players don't get day controls, but can still create tasks for the workers --}}
      <div class="kctg-day-strip">
        <span style="flex:1;min-width:0;"></span>
        <button class="kctg-add-task kctg-btn kctg-btn-gold kctg-btn-xs" type="button" style="flex-shrink:0;"><i class="fas fa-plus"></i> Add Task</button>
      </div>
      {{/if}}

      {{#if tasks.length}}
      <ul class="kctg-task-list">
        {{#each tasks}}
        <li class="kctg-task-card kctg-status-{{status}}">

          {{#if isActive}}
          <div class="kctg-task-card-top">
            <div class="kctg-progress-bar" style="flex:1;">
              <div class="kctg-progress-fill" style="width:{{progressPct}}%"></div>
              <div class="kctg-progress-phases">
                <div class="kctg-phase-mark" style="left:{{kctg_pct (kctg_divide travelDays durationDays)}}%" title="Arrived"></div>
                <div class="kctg-phase-mark kctg-phase-return" style="left:{{kctg_pct (kctg_divide (kctg_add travelDays taskDays) durationDays)}}%" title="Returning"></div>
              </div>
            </div>
            <span class="kctg-elapsed-lbl" style="white-space:nowrap;flex-shrink:0;">Day {{elapsed}} / {{durationDays}}</span>
            {{#if daysLeft}}<span class="kctg-days-left" style="white-space:nowrap;flex-shrink:0;">{{daysLeft}}d left</span>{{/if}}
          </div>
          {{else if isComplete}}
          <div class="kctg-task-card-top">
            <div class="kctg-progress-bar" style="flex:1;">
              <div class="kctg-progress-fill kctg-fill-complete" style="width:100%"></div>
            </div>
            <span class="kctg-elapsed-lbl" style="color:var(--kctg-gold);white-space:nowrap;flex-shrink:0;"><i class="fas fa-check-circle"></i> Complete</span>
          </div>
          {{/if}}

          <div class="kctg-task-card-mid">
            <i class="{{typeIcon}}" style="color:{{typeColor}};flex-shrink:0;width:14px;text-align:center;font-size:.8rem;"></i>
            <input class="kctg-task-name kctg-input kctg-input-sub" type="text" value="{{name}}" data-id="{{id}}" placeholder="Task name" style="flex:1;min-width:0;" />
            <select class="kctg-task-type kctg-select kctg-select-sm" data-id="{{id}}" style="flex-shrink:0;">
              {{#each @root.taskTypeList}}<option value="{{id}}" {{#if (eq id ../type)}}selected{{/if}}>{{label}}</option>{{/each}}
            </select>
            <button class="kctg-delete-task kctg-btn kctg-btn-danger kctg-btn-xs" data-id="{{id}}" type="button"><i class="fas fa-times"></i></button>
          </div>

          <div class="kctg-duration-row">
            <span class="kctg-dur-lbl">Travel</span>
            <input class="kctg-task-travel-days kctg-input-qty" type="number" min="0" value="{{travelDays}}" data-id="{{id}}" />
            <span class="kctg-dur-arrow">+</span>
            <span class="kctg-dur-lbl">Task</span>
            <input class="kctg-task-task-days kctg-input-qty" type="number" min="1" value="{{taskDays}}" data-id="{{id}}" />
            {{#if isBoosted}}
            <span class="kctg-dur-arrow" style="color:var(--kctg-success)">→</span>
            <span class="kctg-dur-value" style="color:var(--kctg-success);font-size:.76rem;flex-shrink:0;" title="Effective task days">{{effectTaskDays}}d</span>
            {{/if}}
            <span class="kctg-dur-arrow">+</span>
            <span class="kctg-dur-lbl">Return</span>
            <span class="kctg-dur-value">{{travelDays}}d</span>
            <span class="kctg-dur-eq">=</span>
            <span class="kctg-dur-value kctg-gold-text" style="font-weight:700;">{{durationDays}}d</span>
            <i class="fas fa-info-circle" style="margin-left:auto;color:var(--kctg-text-muted);font-size:.7rem;flex-shrink:0;cursor:help;" title="Duration = 2× travel + task days. Auto-completes when day counter reaches this total."></i>
          </div>

          {{#if isTradeTask}}
          <div class="kctg-task-route-row">
            <i class="fas fa-route" style="color:var(--kctg-gold-dim);flex-shrink:0;" title="Select a map route"></i>
            <select class="kctg-task-route-select kctg-select kctg-select-sm" data-id="{{id}}" style="flex:1;min-width:0;">
              <option value="">— no route —</option>
              {{#each @root.mapRoutes}}
              <option value="{{id}}" data-travel-days="{{travelDays}}" {{#if (eq id ../routeId)}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            {{#if linkedRouteName}}
            <span style="font-size:0.68rem;color:var(--kctg-gold-dim);white-space:nowrap;"><i class="fas fa-clock"></i> {{linkedRouteTravelDays}}d</span>
            {{/if}}
          </div>
          {{/if}}

          {{#if isPatrolTask}}
          <div class="kctg-task-route-row">
            <i class="fas fa-map-marker-alt" style="color:var(--kctg-gold-dim);flex-shrink:0;" title="Select patrol destination"></i>
            <select class="kctg-task-loc-select kctg-select kctg-select-sm" data-id="{{id}}" style="flex:1;min-width:0;">
              <option value="">— no location —</option>
              {{#each @root.mapLocations}}
              <option value="{{id}}" {{#if (eq id ../locationId)}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
            {{#if linkedLocationName}}
            <span style="font-size:0.68rem;color:var(--kctg-gold-dim);white-space:nowrap;"><i class="fas fa-map-marker-alt"></i> {{linkedLocationName}}</span>
            {{/if}}
          </div>
          {{/if}}

          <div class="kctg-task-workers">
            <span class="kctg-workers-label"><i class="fas fa-users"></i> Workers:</span>
            {{#each assignedWorkers}}
              <span class="kctg-worker-tag">
                <img src="{{img}}" alt="{{name}}" onerror="this.src='icons/svg/mystery-man.svg'" />
                {{name}}
                <button class="kctg-task-unassign-worker kctg-btn kctg-btn-xs" data-task-id="{{../id}}" data-worker-id="{{id}}" type="button" style="padding:0 4px;border:none;background:transparent;color:var(--kctg-danger);">×</button>
              </span>
            {{/each}}
            {{#if (or idleWorkers.length idleGroups.length)}}
            <select class="kctg-task-assign-select kctg-select kctg-select-sm" data-id="{{id}}">
              <option value="">+ Assign…</option>
              {{#if idleGroups.length}}<optgroup label="── Groups ──">{{#each idleGroups}}<option value="group:{{id}}">⬡ {{name}} ({{idleCount}} idle)</option>{{/each}}</optgroup>{{/if}}
              {{#if idleWorkers.length}}<optgroup label="── Workers ──">{{#each idleWorkers}}<option value="{{id}}">{{name}}</option>{{/each}}</optgroup>{{/if}}
            </select>
            {{/if}}
          </div>

          <div class="kctg-task-bottom-row">
            <div class="kctg-task-table-slot kctg-drop-zone" data-id="{{id}}">
              {{#if tableUuid}}
                <i class="fas fa-dice-d20" style="color:var(--kctg-gold-dim)"></i>
                <span class="kctg-table-name" style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{tableName}}</span>
                <button class="kctg-task-clear-table kctg-btn kctg-btn-xs kctg-btn-danger" data-id="{{id}}" type="button">×</button>
              {{else}}
                <i class="fas fa-dice-d20 kctg-dim"></i>
                <span class="kctg-table-placeholder">Drop Result Table</span>
              {{/if}}
            </div>
            <button class="kctg-task-roll-event kctg-btn kctg-btn-outline kctg-btn-xs" data-id="{{id}}" type="button" title="Roll a random event for this task"><i class="fas fa-exclamation-triangle"></i> Event</button>
            {{#if tableUuid}}{{#unless isComplete}}
              <button class="kctg-task-run kctg-btn kctg-btn-outline kctg-btn-xs" data-id="{{id}}" type="button" title="Draw from result table and mark complete"><i class="fas fa-dice-d20"></i> Run</button>
            {{/unless}}{{/if}}
            {{#unless isActive}}{{#unless isComplete}}
              <button class="kctg-task-set-active kctg-btn kctg-btn-gold kctg-btn-xs" data-id="{{id}}" type="button"><i class="fas fa-running"></i> Activate</button>
            {{/unless}}{{/unless}}
            {{#if isComplete}}
              <button class="kctg-task-set-active kctg-btn kctg-btn-outline kctg-btn-xs" data-id="{{id}}" type="button" style="color:#9a8f7a;border-color:#9a8f7a;"><i class="fas fa-undo"></i> Reset</button>
            {{/if}}
            {{#if hasItems}}<button class="kctg-task-collect kctg-btn kctg-btn-gold kctg-btn-xs" data-id="{{id}}" type="button"><i class="fas fa-hand-holding"></i> Collect</button>{{/if}}
          </div>

          {{#if results.length}}
          <div class="kctg-task-results">
            <span class="kctg-label" style="font-size:.68rem;"><i class="fas fa-scroll"></i> Last Results</span>
            <div class="kctg-result-tags">{{#each results}}<span class="kctg-result-tag">{{this}}</span>{{/each}}</div>
          </div>
          {{/if}}

        </li>
        {{/each}}
      </ul>
      {{else}}
        <div class="kctg-empty-state"><i class="fas fa-tasks kctg-empty-icon"></i><p>No tasks. Click <strong>Add Task</strong> to begin.</p></div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- ═══ MAP ═══ --}}
    {{#if isMap}}
    <div class="kctg-app kctg-trade-map-inner kctg-map-tab-embed">

      <div class="kctg-map-toolbar">
        {{#if isGM}}
          <button class="kctg-map-toggle-edit kctg-btn kctg-btn-sm {{#if editMode}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}"
                  type="button" title="Toggle Edit Mode — enables pin management and route drawing">
            <i class="fas fa-edit"></i> Edit {{#if editMode}}ON{{else}}OFF{{/if}}
          </button>
          {{#if editMode}}
            <button class="kctg-map-set-bg kctg-btn kctg-btn-outline kctg-btn-sm" type="button">
              <i class="fas fa-image"></i> Set BG
            </button>
            {{#if hasBackground}}
              <button class="kctg-map-clear-bg kctg-btn kctg-btn-danger kctg-btn-sm" type="button" title="Remove background image">
                <i class="fas fa-times"></i>
              </button>
            {{/if}}
            <div class="kctg-toolbar-sep"></div>
            <button class="kctg-map-toggle-place kctg-btn kctg-btn-sm {{#if placeMode}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}"
                    type="button" title="Click to enable, then click the map to place one location">
              <i class="fas fa-map-marker-alt"></i> {{#if placeMode}}Click to place…{{else}}Place Pin{{/if}}
            </button>
            <button class="kctg-map-toggle-route kctg-btn kctg-btn-sm {{#if routeMode}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}"
                    type="button" title="Click to enable, then click two pins to draw a route between them">
              <i class="fas fa-route"></i> {{#if routeMode}}{{#if pendingFrom}}Click 2nd pin…{{else}}Click pin…{{/if}}{{else}}Place Route{{/if}}
            </button>
            <button class="kctg-map-toggle-wp kctg-btn kctg-btn-sm {{#if waypointMode}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}"
                    type="button" title="Toggle nodes on the route, that can be edited. Click to add, right-click to remove, drag to reposition.">
              <i class="fas fa-bezier-curve"></i> {{#if waypointMode}}Place WP…{{else}}Place WP{{/if}}
            </button>
            {{#if routeMode}}
              {{#if pendingFrom}}
                <span class="kctg-map-hint" style="color:var(--kctg-gold)">
                  <i class="fas fa-route"></i> Click a second pin · same pin to cancel
                </span>
              {{else}}
                <span class="kctg-map-hint">Click a pin to start a route · double-click to edit</span>
              {{/if}}
            {{else}}
              <span class="kctg-map-hint">Double-click a pin to edit</span>
            {{/if}}
          {{/if}}
          <button class="kctg-map-set-view kctg-btn kctg-btn-outline kctg-btn-sm" type="button" title="Save current pan/zoom as reset point">
            <i class="fas fa-bookmark"></i> {{#if hasSavedView}}Resave View{{else}}Set View{{/if}}
          </button>
        {{/if}}
        <button class="kctg-map-reset-pan kctg-btn kctg-btn-outline kctg-btn-sm" type="button" title="{{#if hasSavedView}}Return to saved view{{else}}Reset map position and zoom{{/if}}">
          <i class="fas fa-compress-arrows-alt"></i>
        </button>
        <div class="kctg-zoom-controls">
          <button class="kctg-zoom-out kctg-btn kctg-btn-outline kctg-btn-sm" type="button" title="Zoom out">−</button>
          <span class="kctg-zoom-label">100%</span>
          <button class="kctg-zoom-in  kctg-btn kctg-btn-outline kctg-btn-sm" type="button" title="Zoom in">+</button>
        </div>
      </div>

      <div class="kctg-map-area">
        <div class="kctg-map-canvas">
          <svg class="kctg-map-svg" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              {{#each routes}}
              <linearGradient id="{{gradId}}" data-route-id="{{id}}" gradientUnits="userSpaceOnUse"
                              x1="{{x1pct}}" y1="{{y1pct}}" x2="{{x2pct}}" y2="{{y2pct}}">
                <stop offset="0%"   stop-color="{{fromColor}}" />
                <stop offset="100%" stop-color="{{toColor}}" />
              </linearGradient>
              {{/each}}
            </defs>
            {{#each routes}}
            <g>
              {{#if ../editMode}}
              <path class="kctg-route-hitzone" d="{{pathD}}" fill="none" stroke="transparent" stroke-width="3" data-route-id="{{id}}" />
              {{/if}}
              <path class="kctg-route-line {{#if isActive}}kctg-route-active{{/if}}"
                    d="{{pathD}}" stroke="url(#{{gradId}})" stroke-width="0.5" fill="none"
                    stroke-dasharray="2 1.2" opacity="1" data-route-id="{{id}}" />
            </g>
            {{/each}}
          </svg>
          {{#each locations}}
          <div class="kctg-map-pin {{#if ../editMode}}kctg-pin-edit{{/if}} {{#if (eq id ../pendingFrom)}}kctg-pin-pending{{/if}} {{#if (eq id ../homeLocationId)}}kctg-pin-home{{/if}}"
               data-id="{{id}}" style="left:{{xPct}}%;top:{{yPct}}%;{{pinStyle}}">
            <div class="kctg-pin-img-wrap">
              <img src="{{icon}}" alt="{{name}}" onerror="this.src='icons/svg/village.svg'" />
              {{#if tintColor}}<span class="kctg-pin-tint" style="background:{{tintColor}};"></span>{{/if}}
              {{!-- Quest status badge on pin --}}
              {{#if questStatus}}
                {{#if (eq questStatus "active")}}
                  <span class="kctg-pin-quest-badge kctg-pin-quest-active" title="Active quest here"><i class="fas fa-scroll"></i></span>
                {{else if (eq questStatus "completed")}}
                  <span class="kctg-pin-quest-badge kctg-pin-quest-done" title="Quest completed"><i class="fas fa-check"></i></span>
                {{/if}}
              {{/if}}
            </div>
            <span class="kctg-pin-label">{{name}}</span>
          </div>
          {{/each}}

          {{#if editMode}}
          {{#each routes}}{{#each wpHandles}}
          <div class="kctg-wp-handle" data-route-id="{{../id}}" data-wp-idx="{{idx}}"
               style="left:{{x}}%;top:{{y}}%;"></div>
          {{/each}}{{/each}}
          {{/if}}

          {{#each travelingWorkers}}
          <div class="kctg-traveler kctg-traveler-{{phase}}"
               data-phase="{{phase}}"
               data-from-x="{{fromXPct}}" data-from-y="{{fromYPct}}"
               data-to-x="{{toXPct}}"   data-to-y="{{toYPct}}"
               data-start-progress="{{startProgress}}"
               data-pts="{{ptsStr}}"
               style="left:{{xPct}}%;top:{{yPct}}%;"
               title="{{name}} — {{taskName}} ({{phase}})">
            <img src="{{img}}" alt="{{name}}" onerror="this.src='icons/svg/mystery-man.svg'" />
            <span class="kctg-traveler-badge"><i class="fas fa-route"></i></span>
          </div>
          {{/each}}
          {{#unless hasBackground}}
          <div class="kctg-map-empty-hint">
            {{#if isGM}}
              <i class="fas fa-image"></i> Click <em>Set BG</em> to add a map image
            {{else}}
              <i class="fas fa-map"></i> Trade map not configured yet
            {{/if}}
          </div>
          {{/unless}}
        </div>
      </div>

      {{#if isGM}}{{#if routes.length}}
      <div class="kctg-route-panel">
        <div class="kctg-panel-header"><i class="fas fa-route"></i> Routes</div>
        {{#each routes}}
        <div class="kctg-route-list-row">
          <i class="fas fa-arrows-alt-h" style="color:{{color}};font-size:0.7rem;"></i>
          <span style="flex:1;font-size:0.8rem;color:var(--kctg-text-dim);">{{name}}</span>
          <label style="font-size:0.68rem;color:var(--kctg-gold-dim);white-space:nowrap;" title="Preset travel days"><i class="fas fa-clock"></i></label>
          <input class="kctg-route-travel-days kctg-input-qty kctg-route-days-input" type="number" min="1"
                 value="{{travelDays}}" data-id="{{id}}"
                 title="Travel days (preset for tasks)" />
          <button class="kctg-route-delete kctg-btn kctg-btn-sm kctg-btn-danger"
                  data-id="{{id}}" type="button" title="Delete route"><i class="fas fa-times"></i></button>
        </div>
        {{/each}}
      </div>
      {{/if}}{{/if}}

    </div>
    {{/if}}

    {{!-- ═══ TRADE ORDERS ═══ --}}
    {{#if isTradeOrders}}
    <div class="kctg-trade-orders-tab">
      {{#if tradeOrderCities.length}}
      <div class="kctg-to-layout">

        {{!-- ── Left city list ── --}}
        <div class="kctg-to-city-list">
          <ul class="kctg-to-city-rows">
            {{#each tradeOrderCities}}
            <li class="kctg-to-city-row {{#if isSelected}}kctg-to-city-selected{{/if}}" data-id="{{id}}">
              <img src="{{icon}}" alt="{{name}}" onerror="this.src='icons/svg/village.svg'" class="kctg-to-city-icon" />
              <span class="kctg-to-city-name">{{name}}</span>
              {{#if orderCount}}<span class="kctg-tab-badge">{{orderCount}}</span>{{/if}}
            </li>
            {{/each}}
          </ul>
        </div>

        {{!-- ── Right orders panel ── --}}
        <div class="kctg-to-orders-panel">
          {{#if selectedCity}}

          {{!-- City panel header with controls --}}
          <div class="kctg-to-panel-header">
            <img src="{{selectedCity.icon}}" alt="{{selectedCity.name}}" onerror="this.src='icons/svg/village.svg'" class="kctg-to-city-icon" />
            <strong class="kctg-to-panel-title">{{selectedCity.name}}</strong>
            {{!-- Order management is GM-only: players fulfil orders, they don't create them --}}
            {{#if isGM}}
            {{!-- Settings (toggles the inline strip below) --}}
            <button class="kctg-to-settings-toggle kctg-btn kctg-btn-outline kctg-btn-xs {{#if toSettingsOpen}}kctg-btn-gold{{/if}}" type="button" title="Trade order settings"><i class="fas fa-cog"></i></button>
            {{!-- Roll Table slot --}}
            <div class="kctg-to-city-table-slot kctg-drop-zone-sm" data-loc-id="{{selectedCity.id}}" title="Drop a RollTable here for random orders">
              {{#if selectedCity.cityTableUuid}}
                <i class="fas fa-dice-d20" style="color:var(--kctg-gold-dim);font-size:.7rem;"></i>
                <span class="kctg-to-city-table-name" title="{{selectedCity.cityTableUuid}}">{{selectedCity.cityTableName}}</span>
                <button class="kctg-to-clear-city-table kctg-btn kctg-btn-xs kctg-btn-danger" data-loc-id="{{selectedCity.id}}" type="button" title="Clear table">×</button>
              {{else}}
                <i class="fas fa-dice-d20 kctg-dim" style="font-size:.7rem;"></i>
                <span style="font-size:.68rem;color:var(--kctg-text-muted);">Drop table</span>
              {{/if}}
            </div>
            <button class="kctg-to-random-order kctg-btn kctg-btn-xs kctg-btn-outline" data-loc-id="{{selectedCity.id}}" data-loc-name="{{selectedCity.name}}" type="button" title="Generate a random order (uses the city's roll table if one is set)"><i class="fas fa-random"></i> Random</button>
            <button class="kctg-to-add-order    kctg-btn kctg-btn-xs kctg-btn-gold"    data-loc-id="{{selectedCity.id}}" type="button"><i class="fas fa-plus"></i> Add</button>
            {{/if}}
          </div>

          {{!-- Settings strip (inline, GM-only) — mirrors the Workers tab Settings bar --}}
          {{#if isGM}}{{#if toSettingsOpen}}
          <div class="kctg-settings-panel">
            <div class="kctg-settings-inline-row kctg-to-settings-inline-row">
              <span class="kctg-settings-lbl">Min Qty</span>
              <input class="kctg-setting-input kctg-input-qty" type="number" min="1" max="999" data-setting="tradeOrderQtyMin" value="{{tradeQtyMin}}" />
              <span class="kctg-settings-sep"></span>
              <span class="kctg-settings-lbl">Max Qty</span>
              <input class="kctg-setting-input kctg-input-qty" type="number" min="1" max="999" data-setting="tradeOrderQtyMax" value="{{tradeQtyMax}}" />
              <span class="kctg-settings-sep"></span>
              <span class="kctg-settings-lbl">Variance %</span>
              <input class="kctg-setting-input kctg-input-qty" type="number" min="0" max="100" step="5" data-setting="tradeOrderPriceVariance" value="{{tradeVariance}}" />
              <span class="kctg-settings-sep"></span>
              <span class="kctg-settings-lbl">Permissions</span>
              <button class="kctg-to-toggle-pedit kctg-btn kctg-btn-xs {{#if playerEditOrders}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}" type="button" title="Let players edit existing orders (creating new orders stays GM-only)"><i class="fas fa-user-pen"></i> Players Edit</button>
              <button class="kctg-to-toggle-force kctg-btn kctg-btn-xs {{#if allowForce}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}" type="button" title="Show the GM-only Force-complete button on orders (grant reward without the goods)"><i class="fas fa-bolt"></i> Force (GM)</button>
            </div>
          </div>
          {{/if}}{{/if}}

          {{!-- Order cards --}}
          {{#if selectedCityOrders.length}}
          <div class="kctg-to-order-list">
            {{#each selectedCityOrders}}
            <div class="kctg-to-order-card {{#if collapsed}}kctg-to-order-collapsed{{/if}} {{#if fulfilled}}kctg-to-order-fulfilled{{/if}} {{#if questLocked}}kctg-to-order-locked{{/if}} {{#if expired}}kctg-to-order-expired{{/if}}" data-id="{{id}}">

              {{!-- Card header: collapse toggle + name + delete --}}
              <div class="kctg-to-order-header">
                <button class="kctg-to-order-collapse kctg-btn-bare" data-id="{{id}}" type="button" title="Collapse / expand">
                  <i class="fas fa-chevron-{{#if collapsed}}right{{else}}down{{/if}}" style="font-size:.65rem;color:var(--kctg-text-muted);"></i>
                </button>
                {{#if @root.canManageOrders}}
                  <input class="kctg-to-order-name kctg-input kctg-input-sub" type="text" value="{{name}}" data-id="{{id}}" placeholder="Order name…" style="flex:1;" />
                {{else}}
                  <span class="kctg-to-order-name-static">{{name}}</span>
                {{/if}}
                {{#if questLocked}}<span class="kctg-to-locked-tag" title="Unlocks when the quest &quot;{{linkedQuestName}}&quot; is completed"><i class="fas fa-lock"></i> {{linkedQuestName}}</span>{{/if}}
                {{#unless fulfilled}}
                  {{#if expired}}
                    <span class="kctg-to-expired-tag" title="Not delivered by day {{dueDay}}"><i class="fas fa-hourglass-end"></i> Expired</span>
                  {{else if late}}
                    <span class="kctg-to-overdue-tag" title="Past its day {{dueDay}} deadline - still deliverable at {{latePenaltyPct}}% reduced payment"><i class="fas fa-hourglass-half"></i> Overdue &minus;{{latePenaltyPct}}%</span>
                  {{else if dueDay}}
                    <span class="kctg-to-due-tag" title="Due by workshop day {{dueDay}}"><i class="fas fa-hourglass-half"></i> Due day {{dueDay}} ({{daysLeft}}d)</span>
                  {{/if}}
                {{/unless}}
                {{#if fulfilled}}<span class="kctg-to-fulfilled-dot" title="Fulfilled{{#if fulfilledLate}} late{{/if}}"><i class="fas fa-check-circle"></i></span>{{/if}}
                {{#if @root.canManageOrders}}<button class="kctg-to-delete-order kctg-btn kctg-btn-danger kctg-btn-xs" data-id="{{id}}" type="button" title="Delete"><i class="fas fa-times"></i></button>{{/if}}
              </div>

              {{!-- Description --}}
              {{#if @root.canManageOrders}}
                <textarea class="kctg-to-order-desc kctg-input kctg-textarea" rows="2" data-id="{{id}}" placeholder="Description (optional)…">{{description}}</textarea>
              {{else}}{{#if description}}
                <p class="kctg-to-order-desc-static">{{description}}</p>
              {{/if}}{{/if}}

              {{!-- Needs / Pays (hidden when collapsed) --}}
              {{#unless collapsed}}

              {{!-- Deadline + quest link (contract administration, same gate as field edits) --}}
              {{#if @root.canManageOrders}}
              <div class="kctg-to-deadline-row">
                <span class="kctg-to-deadline-lbl" title="Workshop day the delivery is due (leave empty for no deadline)"><i class="fas fa-hourglass-half"></i> Due day</span>
                <input class="kctg-to-due-day kctg-input-qty" type="number" min="0" placeholder="none" value="{{dueDay}}" data-id="{{id}}" style="width:58px;" />
                {{#if dueDay}}
                <select class="kctg-to-late-mode kctg-select kctg-select-sm" data-id="{{id}}" title="What happens after the due day">
                  <option value="expire"  {{#unless lateModePenalty}}selected{{/unless}}>then expires</option>
                  <option value="penalty" {{#if lateModePenalty}}selected{{/if}}>late at a loss</option>
                </select>
                {{#if lateModePenalty}}
                <input class="kctg-to-late-pct kctg-input-qty" type="number" min="0" max="100" step="5" value="{{latePenaltyPct}}" data-id="{{id}}" title="Percent removed from the payment when delivered late" style="width:48px;" />
                <span class="kctg-to-deadline-hint">% off pay</span>
                {{/if}}
                {{/if}}
                <span class="kctg-settings-sep"></span>
                <div class="kctg-to-quest-slot kctg-drop-zone-sm" data-id="{{id}}" title="Drop a Quest journal page here - the order stays locked until that quest is completed">
                  {{#if linkedQuestName}}
                    <i class="fas fa-{{#if questLocked}}lock{{else}}unlock{{/if}}" style="color:var(--kctg-amber);font-size:.7rem;"></i>
                    <span class="kctg-to-quest-name">{{linkedQuestName}}</span>
                    <button class="kctg-to-quest-clear kctg-btn kctg-btn-xs kctg-btn-danger" data-id="{{id}}" type="button" title="Unlink quest">×</button>
                  {{else}}
                    <i class="fas fa-scroll kctg-dim" style="font-size:.7rem;"></i>
                    <span class="kctg-to-deadline-hint">Drop quest to lock</span>
                  {{/if}}
                </div>
              </div>
              {{/if}}

              <div class="kctg-to-order-split">

                <div class="kctg-to-col">
                  <div class="kctg-to-col-header"><i class="fas fa-arrow-down" style="color:var(--kctg-danger);font-size:.7rem;"></i> Needs</div>
                  {{#if needs.length}}
                    {{#each needs}}
                    <div class="kctg-to-split-row">
                      {{#if itemImg}}<img src="{{itemImg}}" alt="{{itemName}}" onerror="this.src='icons/svg/item-bag.svg'" class="kctg-to-row-img" />{{/if}}
                      <span class="kctg-to-item-label">{{itemName}}</span>
                      <span class="kctg-to-sep-dim">×</span>
                      {{#if @root.canManageOrders}}
                        <input class="kctg-to-need-qty kctg-input-qty" type="number" min="1" value="{{qty}}" data-order-id="{{../id}}" data-need-id="{{id}}" style="width:42px;" />
                      {{else}}
                        <span class="kctg-to-static-qty">{{qty}}</span>
                      {{/if}}
                      {{#if @root.hasWsActor}}<span class="kctg-to-have {{#if enough}}kctg-to-have-ok{{else}}kctg-to-have-low{{/if}}" title="In workshop stock">{{have}} in stock</span>{{/if}}
                      {{#if @root.canManageOrders}}<button class="kctg-to-del-need kctg-btn kctg-btn-xs kctg-btn-danger" data-order-id="{{../id}}" data-need-id="{{id}}" type="button">×</button>{{/if}}
                    </div>
                    {{/each}}
                  {{else}}
                    <p class="kctg-subtle" style="font-size:.72rem;margin:4px 0;">No items yet.</p>
                  {{/if}}
                  {{#if @root.canManageOrders}}
                  <div class="kctg-to-needs-drop kctg-drop-zone-sm" data-order-id="{{id}}" style="margin-top:4px;">
                    <i class="fas fa-plus" style="font-size:.6rem;"></i> Drop item
                  </div>
                  {{/if}}
                </div>

                <div class="kctg-to-col">
                  <div class="kctg-to-col-header"><i class="fas fa-arrow-up" style="color:var(--kctg-success);font-size:.7rem;"></i> Pays</div>
                  {{#if pays.length}}
                    {{#each pays}}
                    <div class="kctg-to-split-row">
                      {{#if @root.canManageOrders}}
                        {{#if (eq type "item")}}
                          <div class="kctg-to-pay-item-drop kctg-drop-zone-sm" data-order-id="{{../id}}" data-pay-id="{{id}}" title="Drop item to replace">
                            {{#if itemImg}}<img src="{{itemImg}}" onerror="this.src='icons/svg/item-bag.svg'" class="kctg-to-row-img" />{{/if}}
                            <input class="kctg-to-pay-item-name" type="text" value="{{itemName}}" data-order-id="{{../id}}" data-pay-id="{{id}}" placeholder="item…" style="width:60px;" />
                          </div>
                          <span class="kctg-to-sep-dim">×</span>
                          <input class="kctg-to-pay-value kctg-input-qty" type="number" min="1" value="{{value}}" data-order-id="{{../id}}" data-pay-id="{{id}}" style="width:36px;" />
                        {{else}}
                          <input class="kctg-to-pay-value kctg-input-qty" type="number" min="1" value="{{value}}" data-order-id="{{../id}}" data-pay-id="{{id}}" style="width:42px;" />
                          <select class="kctg-to-pay-type kctg-select kctg-select-sm" data-order-id="{{../id}}" data-pay-id="{{id}}">
                            <option value="gp"   {{#if (eq type "gp")}}selected{{/if}}>gp</option>
                            <option value="sp"   {{#if (eq type "sp")}}selected{{/if}}>sp</option>
                            <option value="cp"   {{#if (eq type "cp")}}selected{{/if}}>cp</option>
                            <option value="item" {{#if (eq type "item")}}selected{{/if}}>item</option>
                          </select>
                        {{/if}}
                        <button class="kctg-to-del-payment kctg-btn kctg-btn-xs kctg-btn-danger" data-order-id="{{../id}}" data-pay-id="{{id}}" type="button">×</button>
                      {{else}}
                        {{#if (eq type "item")}}
                          {{#if itemImg}}<img src="{{itemImg}}" onerror="this.src='icons/svg/item-bag.svg'" class="kctg-to-row-img" />{{/if}}
                          <span class="kctg-to-item-label">{{itemName}}</span>
                          <span class="kctg-to-sep-dim">×</span>
                          <span class="kctg-to-static-qty">{{value}}</span>
                        {{else}}
                          <span class="kctg-to-static-pay">{{value}} {{type}}</span>
                        {{/if}}
                      {{/if}}
                    </div>
                    {{/each}}
                  {{else}}
                    <p class="kctg-subtle" style="font-size:.72rem;margin:4px 0;">No payment yet.</p>
                  {{/if}}
                  {{#if @root.canManageOrders}}
                  <div class="kctg-to-pays-drop kctg-drop-zone-sm" data-order-id="{{id}}" style="margin-top:4px;">
                    <i class="fas fa-plus" style="font-size:.6rem;"></i> Drop item/coin
                  </div>
                  <button class="kctg-to-add-pay kctg-btn kctg-btn-xs kctg-btn-outline" data-id="{{id}}" type="button" style="margin-top:4px;"><i class="fas fa-coins"></i> Add currency</button>
                  {{/if}}
                </div>

              </div>{{!-- end split --}}

              {{!-- Fulfil: deliver the goods from the workshop, collect the payment --}}
              {{#if @root.hasWsActor}}
              <div class="kctg-to-order-footer">
                {{#if fulfilled}}
                  <span class="kctg-to-fulfilled-tag"><i class="fas fa-check-circle"></i> Fulfilled{{#if fulfilledLate}} (late){{/if}}</span>
                  {{!-- Reopen re-enables the reward, so it follows the edit gate
                        (GM, or players when player-editing is enabled). --}}
                  {{#if @root.canManageOrders}}
                  <button class="kctg-to-reopen kctg-btn kctg-btn-sm kctg-btn-outline"
                          data-id="{{id}}" type="button" title="Reopen this order so it can be fulfilled again">
                    <i class="fas fa-undo"></i> Reopen
                  </button>
                  {{/if}}
                {{else}}
                  {{#if questLocked}}
                    <span class="kctg-to-expired-note"><i class="fas fa-lock"></i> Locked until "{{linkedQuestName}}" is completed</span>
                  {{else if expired}}
                    <span class="kctg-to-expired-note"><i class="fas fa-hourglass-end"></i> Expired on day {{dueDay}}{{#if @root.canManageOrders}} - set a later due day to revive it{{/if}}</span>
                    {{!-- Force stays available: it is the GM override by nature --}}
                    {{#if @root.showForce}}
                    <button class="kctg-to-force-fulfill kctg-btn kctg-btn-sm kctg-btn-outline"
                            data-id="{{id}}" type="button"
                            title="GM: complete this expired order anyway and grant the reward">
                      <i class="fas fa-bolt"></i> Force
                    </button>
                    {{/if}}
                  {{else}}
                    {{#if @root.showForce}}
                    <button class="kctg-to-force-fulfill kctg-btn kctg-btn-sm kctg-btn-outline"
                            data-id="{{id}}" type="button"
                            title="GM: complete this order without delivering the goods (speculative / random orders), and grant the reward">
                      <i class="fas fa-bolt"></i> Force
                    </button>
                    {{/if}}
                    <button class="kctg-to-fulfill kctg-btn kctg-btn-sm {{#if canFulfill}}kctg-btn-gold{{else}}kctg-btn-outline{{/if}}"
                            data-id="{{id}}" type="button" {{#unless canFulfill}}disabled{{/unless}}
                            title="{{#if late}}Deliver the goods late: the payment is reduced by {{latePenaltyPct}}%{{else}}Deliver the required goods from the workshop's stock and collect the payment{{/if}}">
                      <i class="fas fa-handshake"></i> {{#if canFulfill}}{{#if late}}Fulfill Late (&minus;{{latePenaltyPct}}%){{else}}Fulfill Order{{/if}}{{else}}Not enough materials{{/if}}
                    </button>
                  {{/if}}
                {{/if}}
              </div>
              {{/if}}
              {{/unless}}{{!-- end unless collapsed --}}

            </div>{{!-- end order card --}}
            {{/each}}
          </div>
          {{else}}
            <div class="kctg-to-empty"><i class="fas fa-inbox kctg-dim"></i> No Orders{{#if isGM}} - Click <strong>Add</strong> or <strong>Random</strong>{{/if}}</div>
          {{/if}}

          {{/if}}{{!-- end selectedCity --}}
        </div>{{!-- end orders panel --}}

      </div>{{!-- end layout --}}
      {{else}}
        <div class="kctg-empty-state">
          <i class="fas fa-map-marker-alt kctg-empty-icon"></i>
          <p>No cities on the Trade Map yet.</p>
          <p style="font-size:.78rem;color:var(--kctg-text-muted);">Add pins on the Trade Map to create cities, then return here to add trade orders.</p>
        </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- ═══ INVENTORY ═══ --}}
    {{#if isInventory}}
    {{#if wsActor}}
      <div class="kctg-ws-art-layer" style="background-image:url('{{wsActor.img}}');"></div>
    {{/if}}
    <div class="kctg-inventory-tab">

      <div class="kctg-inv-header-bar">
        <i class="fas fa-info-circle" style="color:var(--kctg-gold-dim);flex-shrink:0;"></i>
        <span class="kctg-inv-info-text">Items from the Retainer. Removing also removes from the Retainer's sheet.</span>
        {{#if invGp}}<span class="kctg-coin-chip kctg-coin-gp">{{invGp}} gp</span>{{/if}}
        {{#if invSp}}<span class="kctg-coin-chip kctg-coin-sp">{{invSp}} sp</span>{{/if}}
        {{#if invCp}}<span class="kctg-coin-chip kctg-coin-cp">{{invCp}} cp</span>{{/if}}
        {{#if isGM}}<button class="kctg-inv-add-folder kctg-btn kctg-btn-outline kctg-btn-xs" type="button"><i class="fas fa-folder-plus"></i> Folder</button>{{/if}}
      </div>

      {{#if allInvItems.length}}

        <ul class="kctg-inv-grid kctg-inv-drop-zone kctg-inv-ungrouped-drop" data-folder-id="">
          {{#each ungroupedInvItems}}
          <li class="kctg-inv-card" draggable="true" data-inv-id="{{id}}" data-actor-id="{{actorId}}" data-embedded-id="{{embeddedItemId}}">
            <i class="fas fa-grip-vertical kctg-inv-drag-handle"></i>
            <img src="{{itemImg}}" alt="{{itemName}}" onerror="this.src='icons/svg/item-bag.svg'" class="kctg-item-img" />
            <span class="kctg-item-name" title="{{itemName}}">{{itemName}}</span>
            {{#if priceLabel}}<span class="kctg-inv-price">{{priceLabel}}</span>{{/if}}
            <span class="kctg-item-qty">×{{qty}}</span>
            <button class="kctg-item-info kctg-btn-icon" type="button" title="Show description"><i class="fas fa-circle-info"></i></button>
            <button class="kctg-inv-remove kctg-btn kctg-btn-danger kctg-btn-xs" data-id="{{id}}" type="button" title="Remove"><i class="fas fa-times"></i></button>
          </li>
          {{/each}}
        </ul>

        {{#each invFolderList}}
        <div class="kctg-inv-folder-section">
          <div class="kctg-inv-folder-header">
            <button class="kctg-inv-folder-toggle kctg-btn-bare" data-id="{{id}}" type="button">
              <i class="fas fa-folder{{#unless collapsed}}-open{{/unless}}" style="color:var(--kctg-gold-dim)"></i>
            </button>
            <input class="kctg-inv-folder-name kctg-input kctg-input-sub" type="text" value="{{name}}" data-id="{{id}}" placeholder="Folder name" {{#unless @root.isGM}}readonly{{/unless}} />
            <span class="kctg-hint" style="font-size:.72rem;">{{items.length}}</span>
            {{#if @root.isGM}}<button class="kctg-inv-folder-delete kctg-btn kctg-btn-danger kctg-btn-xs" data-id="{{id}}" type="button"><i class="fas fa-times"></i></button>{{/if}}
          </div>
          {{#unless collapsed}}
          <ul class="kctg-inv-grid kctg-inv-drop-zone" data-folder-id="{{id}}">
            {{#each items}}
            <li class="kctg-inv-card" draggable="true" data-inv-id="{{id}}" data-actor-id="{{actorId}}" data-embedded-id="{{embeddedItemId}}">
              <i class="fas fa-grip-vertical kctg-inv-drag-handle"></i>
              <img src="{{itemImg}}" alt="{{itemName}}" onerror="this.src='icons/svg/item-bag.svg'" class="kctg-item-img" />
              <span class="kctg-item-name" title="{{itemName}}">{{itemName}}</span>
              {{#if priceLabel}}<span class="kctg-inv-price">{{priceLabel}}</span>{{/if}}
              <span class="kctg-item-qty">×{{qty}}</span>
              <button class="kctg-item-info kctg-btn-icon" type="button" title="Show description"><i class="fas fa-circle-info"></i></button>
              <button class="kctg-inv-remove kctg-btn kctg-btn-danger kctg-btn-xs" data-id="{{id}}" type="button" title="Remove"><i class="fas fa-times"></i></button>
            </li>
            {{/each}}
            {{#unless items.length}}
            <li class="kctg-inv-folder-empty-drop"><i class="fas fa-arrows-alt"></i> Drag items here</li>
            {{/unless}}
          </ul>
          {{/unless}}
        </div>
        {{/each}}

      {{else}}
        <div class="kctg-empty-state"><i class="fas fa-box kctg-empty-icon"></i><p>No items collected yet. Run a task and use <em>Collect to Workshop</em>.</p></div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- ═══ TRACKER ═══ --}}
    {{#if isTracker}}
    <div class="kctg-tracker-panel">

      <div class="kctg-tracker-toolbar">
        <span class="kctg-tracker-title"><i class="fas fa-chart-line"></i> Tracker</span>
        {{#if isGM}}
          <button class="kctg-tracker-add-entry kctg-btn kctg-btn-gold kctg-btn-sm" type="button">
            <i class="fas fa-plus"></i> Add Entry
          </button>
        {{/if}}
      </div>

      <div class="kctg-tracker-list">
        {{#if trackerEntries.length}}
          {{#each trackerEntries}}
          <div class="kctg-tracker-entry {{#if (eq progressPct 100)}}kctg-tracker-entry--done{{/if}}" data-id="{{id}}" draggable="true">
            {{#if ../isGM}}<div class="kctg-tracker-drag-handle" title="Drag to reorder"><i class="fas fa-grip-vertical"></i></div>{{/if}}

            {{!-- Actor avatar --}}
            {{#if ../isGM}}
              <div class="kctg-tracker-actor-drop {{#if actorImg}}kctg-tracker-has-actor{{else}}kctg-tracker-empty-actor{{/if}}" data-id="{{id}}" title="Drop an Actor here">
                {{#if actorImg}}
                  <img class="kctg-tracker-actor-img" src="{{actorImg}}" alt="{{actorName}}" onerror="this.src='icons/svg/mystery-man.svg'" />
                {{else}}
                  <span class="kctg-silhouette"><i class="fas fa-user"></i></span>
                {{/if}}
              </div>
            {{else}}
              <div class="kctg-tracker-actor-view">
                {{#if actorImg}}
                  <img class="kctg-tracker-actor-img" src="{{actorImg}}" alt="{{actorName}}" onerror="this.src='icons/svg/mystery-man.svg'" />
                {{else}}
                  <span class="kctg-silhouette"><i class="fas fa-user"></i></span>
                {{/if}}
              </div>
            {{/if}}

            {{!-- Body --}}
            <div class="kctg-tracker-body">

              {{!-- Top row: actor name, label, remove --}}
              <div class="kctg-tracker-top">
                <span class="kctg-tracker-actor-name">{{#if actorName}}{{actorName}}{{else}}<span class="kctg-tracker-anon">—</span>{{/if}}</span>
                <span class="kctg-tracker-arrow">→</span>
                {{#if ../isGM}}
                  <input class="kctg-tracker-label-input kctg-input kctg-input-sub" type="text" value="{{label}}" data-id="{{id}}" placeholder="Working towards..." />
                {{else}}
                  <span class="kctg-tracker-label">{{label}}</span>
                {{/if}}
                {{#if ../isGM}}
                  <button class="kctg-tracker-remove-btn kctg-btn-icon kctg-danger-icon" data-id="{{id}}" type="button" title="Remove entry"><i class="fas fa-times"></i></button>
                {{/if}}
              </div>

              {{!-- Item tracking section (if has trackedItems) --}}
              {{#if trackedItems.length}}
              <div class="kctg-titem-list">
                {{#each trackedItems}}
                <div class="kctg-titem-row">
                  <img src="{{itemImg}}" alt="{{itemName}}" onerror="this.src='icons/svg/item-bag.svg'" class="kctg-titem-img" />
                  <span class="kctg-titem-name">{{itemName}}</span>
                  {{!-- Per-item progress is tracked manually by the GM --}}
                  {{#if ../../isGM}}
                    <input class="kctg-titem-current kctg-input-qty {{#if (kctg_lte targetQty currentQty)}}kctg-titem-done{{/if}}" type="number" min="0" value="{{currentQty}}" data-entry-id="{{../id}}" data-item-id="{{id}}" title="Current progress" style="width:42px;" />
                  {{else}}
                    <span class="kctg-titem-inv-qty {{#if (kctg_lte targetQty currentQty)}}kctg-titem-done{{/if}}">{{currentQty}}</span>
                  {{/if}}
                  <span class="kctg-tracker-sep">/</span>
                  {{#if ../../isGM}}
                    <input class="kctg-titem-target kctg-input-qty" type="number" min="1" value="{{targetQty}}" data-entry-id="{{../id}}" data-item-id="{{id}}" title="Target qty" style="width:42px;" />
                    <button class="kctg-titem-remove kctg-btn-icon kctg-danger-icon" data-entry-id="{{../id}}" data-item-id="{{id}}" type="button" title="Remove item"><i class="fas fa-times"></i></button>
                  {{else}}
                    <span class="kctg-tracker-fraction">{{targetQty}}</span>
                  {{/if}}
                </div>
                {{/each}}
              </div>
              {{#if ../isGM}}
              <div class="kctg-titem-drop-zone kctg-drop-zone-sm" data-entry-id="{{id}}" title="Drop an item to track">
                <i class="fas fa-plus" style="font-size:.6rem;"></i> Drop item to track
              </div>
              {{/if}}
              {{else}}
              {{!-- Progress tracking (numeric) --}}
              {{#if ../isGM}}
              <div class="kctg-titem-drop-zone kctg-drop-zone-sm" data-entry-id="{{id}}" title="Drop an item to switch to per-item tracking" style="margin-bottom:4px;">
                <i class="fas fa-cube" style="font-size:.6rem;"></i> Drop item to track it
              </div>
              {{/if}}
              {{/if}}

              {{!-- Progress bar (always shown) --}}
              <div class="kctg-tracker-progress-row">
                <div class="kctg-tracker-bar-wrap">
                  <div class="kctg-tracker-bar-fill {{#if (eq progressPct 100)}}kctg-tracker-bar-done{{/if}}" style="width:{{progressPct}}%"></div>
                  <span class="kctg-tracker-bar-pct">{{progressPct}}%</span>
                </div>
                {{!-- Numeric progress (only shown when NOT using item tracking) --}}
                {{#unless trackedItems.length}}
                {{#if ../isGM}}
                  <div class="kctg-tracker-nums">
                    <input class="kctg-tracker-current kctg-input-qty" type="number" min="0" value="{{current}}" data-id="{{id}}" title="Current" />
                    <span class="kctg-tracker-sep">/</span>
                    <input class="kctg-tracker-total kctg-input-qty" type="number" min="1" value="{{total}}" data-id="{{id}}" title="Total" />
                  </div>
                {{else}}
                  <span class="kctg-tracker-fraction">{{current}}<span class="kctg-tracker-sep">/</span>{{total}}</span>
                {{/if}}
                {{/unless}}
              </div>

            </div>{{!-- end tracker-body --}}
          </div>
          {{/each}}
        {{else}}
          <div class="kctg-empty-state">
            <i class="fas fa-chart-line kctg-empty-icon"></i>
            <p>Nothing being tracked yet.</p>
            {{#if isGM}}<p class="kctg-subtle">Click <strong>Add Entry</strong>, then drop items to track per-item progress, or set numeric current/total manually.</p>{{/if}}
          </div>
        {{/if}}
      </div>

    </div>
    {{/if}}

  </div>
</div>
